# AgriTech API Configuration
# Copy this file to .env and fill in your values.
# The Secrets Gradle Plugin will inject these as BuildConfig fields at build time.

# Base URL of the FastAPI crop disease detection server.
# Must end with a trailing slash.
AGRITECH_API_URL=https://hassan2007-agritech-yolo-model.hf.space/api/v1/

# Gemini API key for AI Studio integration (optional).
GEMINI_API_KEY=MY_GEMINI_API_KEY