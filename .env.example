# The base URL of the FastAPI cloud inference engine.
# Make sure this ends with a trailing slash (/).

# For Local Development (running the backend on your own machine):
# Replace <YOUR_LOCAL_IP> with your machine's local IPv4 address.
# AGRITECH_API_URL=http://<YOUR_LOCAL_IP>:8000/api/v1/

# For Cloud Deployment (e.g., Hugging Face Spaces):
AGRITECH_API_URL=https://your-space-name.hf.space/api/v1/